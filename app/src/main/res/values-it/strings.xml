    <string name="onboarding_privacy_title">I tuoi Dati, il tuo Controllo</string>
    <string name="onboarding_privacy_subtitle">Questa app è un inoltratore trasparente. Ecco esattamente come vengono gestiti i tuoi dati:</string>
    <string name="onboarding_privacy_p1">Decidi tu quali tipi di dati sanitari abilitare: nulla viene letto senza la tua scelta</string>
    <string name="onboarding_privacy_p2">Le autorizzazioni vengono richieste solo per i tipi che attivi. Se non abiliti mai un tipo, la sua autorizzazione non viene mai richiesta</string>
    <string name="onboarding_privacy_p3">I tuoi dati vengono inviati direttamente agli URL webhook configurati — in nessun altro posto</string>
    <string name="onboarding_privacy_p4">Niente viene archiviato su server esterni</string>
    <string name="onboarding_privacy_p5">I tuoi dati non vengono mai venduti o condivisi con nessuno</string>
    <string name="onboarding_privacy_footer">Hai feedback o suggerimenti? Vai alla scheda Impostazioni in qualsiasi momento: ci piacerebbe ascoltarti.</string>
    <string name="onboarding_privacy_warning_title">Usa solo la versione ufficiale</string>
    <string name="onboarding_privacy_warning_desc">Le versioni craccate o modificate di questa app possono rubare i tuoi URL webhook o inviare i tuoi dati sanitari a server sconosciuti. Scarica sempre da Google Play.</string>
    <string name="dt_steps_name">Passi</string>
    <string name="dt_steps_rationale">Tieni traccia dei passi giornalieri ed invia i totali alla tua webhook per automazioni.</string>
    <string name="dt_sleep_name">Sonno</string>
    <string name="dt_sleep_rationale">Inoltra durata e fasi del sonno per dashboard personalizzate sulla qualità del sonno.</string>
    <string name="dt_hr_name">Frequenza cardiaca</string>
    <string name="dt_hr_rationale">Trasmetti le letture del battito cardiaco per analisi della salute o dell\’allenamento.</string>
    <string name="dt_hrv_name">Variabilità frequenza cardiaca</string>
    <string name="dt_hrv_rationale">Invia le letture HRV (RMSSD) alla tua webhook per tracciare lo stress.</string>
    <string name="dt_dist_name">Distanza</string>
    <string name="dt_dist_rationale">Inoltra la distanza percorsa al giorno per log di corsa, camminata o bicicletta.</string>
    <string name="dt_act_cal_name">Calorie attive</string>
    <string name="dt_act_cal_rationale">Invia i dati sulle calorie bruciate per tracciare il fitness o stabilire obiettivi.</string>
    <string name="dt_tot_cal_name">Calorie totali</string>
    <string name="dt_tot_cal_rationale">Inoltra le calorie totali spese giornalmente per il bilancio energetico generale.</string>
    <string name="dt_weight_name">Peso</string>
    <string name="dt_weight_rationale">Sincronizza le misurazioni del peso con la webhook per tracciare l\’IMC.</string>
    <string name="dt_height_name">Altezza</string>
    <string name="dt_height_rationale">Inoltra l\’altezza alla tua webhook per attivare il calcolo dell\’IMC e composizione.</string>
    <string name="dt_bp_name">Pressione sanguigna</string>
    <string name="dt_bp_rationale">Inoltra le letture per il controllo cardiovascolare e workflow di allerta.</string>
    <string name="dt_bg_name">Glicemia</string>
    <string name="dt_bg_rationale">Invia il livello di glucosio nel sangue per la gestione e allarmi sulla salute.</string>
    <string name="dt_oxy_name">Saturazione di ossigeno</string>
    <string name="dt_oxy_rationale">Inoltra l\’SpO₂ per monitorare apparato respiratorio e cali di ossigeno.</string>
    <string name="dt_temp_name">Temperatura corporea</string>
    <string name="dt_temp_rationale">Invia le misurazioni della temperatura alla tua webhook per rintracciare patologie o febbri.</string>
    <string name="dt_skin_temp_name">Temperatura cutanea</string>
    <string name="dt_skin_temp_rationale">Invia alla tua webhook i delta di temperatura cutanea dai dispositivi indossabili per benessere e analisi del sonno.</string>
    <string name="dt_resp_name">Frequenza respiratoria</string>
    <string name="dt_resp_rationale">Inoltra il tasso respiratorio per esaminare recuperi o anomalie via webhook.</string>
    <string name="dt_rhr_name">Frequenza cardiaca a riposo</string>
    <string name="dt_rhr_rationale">Invia la frequenza giornaliera a riposo alla tua webhook per analizzare la resistenza.</string>
    <string name="dt_exer_name">Sessioni di esercizio</string>
    <string name="dt_exer_rationale">Inoltra il tipo e durata delle sessioni di allenamento alla tua webhook per analisi fitness.</string>
    <string name="dt_hydr_name">Idratazione</string>
    <string name="dt_hydr_rationale">Inoltra il registro dell\’assunzione idrica alla webhook per automazione del benessere.</string>
    <string name="dt_nutr_name">Nutrizione</string>
    <string name="dt_nutr_rationale">Inoltra i nutrienti essenziali per seguire accuratamente i programmi dietetici stabiliti.</string>
    <string name="dt_bmr_name">Metabolismo basale</string>
    <string name="dt_bmr_rationale">Invia i dati sul TMB alla tua webhook per piani personalizzati dell\’ingestione calorica corporea target.</string>
    <string name="dt_bf_name">Grasso corporeo</string>
    <string name="dt_bf_rationale">Trasmetti ai Webhook i valori delle analisi che consentiranno di confrontare periodi dei vostri risultati in salute.</string>
    <string name="dt_lbm_name">Massa magra</string>
    <string name="dt_lbm_rationale">Trasmetti misure sulla muscolosità nei resoconti forniti tramite il personale Webhook inviato come report.</string>
    <string name="dt_vo2_name">VO₂ Max</string>
    <string name="dt_vo2_rationale">Misura di tolleranza di sopportazione sportiva valutando massimi che passiamo sul tuo riferimento del Webhook.</string>
    <string name="dt_bone_name">Massa ossea</string>
    <string name="dt_bone_rationale">Dati concernenti test scheletrico o la sanità strutturale registrata nel Webhook in prospettiva di checkup fisico.</string>
    <string name="dt_hc_rationale">Health Connect to Webhook richiede l\’accesso ai dati sulla tua salute e forma fisica. Questi dati sono usati rigorosamente per adempiere alla funzionalità base dell\’app: trasmettere in sicurezza tali metriche direttamente ai tuoi Webhook URL personali. Noi non vendiamo o condividiamo in alcun modo le tue info.</string>
