    <string name="onboarding_privacy_title">Tus Datos, Tu Control</string>
    <string name="onboarding_privacy_subtitle">Esta aplicación es un canal transparente. Así es exactamente como se manejan tus datos:</string>
    <string name="onboarding_privacy_p1">Tú decides qué tipos de datos de salud habilitar: no se lee nada sin tu elección</string>
    <string name="onboarding_privacy_p2">Los permisos solo se solicitan para los tipos que activas. Si nunca habilitas un tipo, nunca se solicita su permiso</string>
    <string name="onboarding_privacy_p3">Tus datos se envían directamente a tus propias URL de webhook, a ningún otro lugar</string>
    <string name="onboarding_privacy_p4">No se almacena nada en ningún servidor externo</string>
    <string name="onboarding_privacy_p5">Tus datos nunca se venden ni se comparten con nadie</string>
    <string name="onboarding_privacy_footer">¿Tienes comentarios o sugerencias? Ve a la pestaña Configuración en cualquier momento: nos encantaría escucharte.</string>
    <string name="onboarding_privacy_warning_title">Usa solo la versión oficial</string>
    <string name="onboarding_privacy_warning_desc">Las versiones no oficiales o modificadas de esta aplicación pueden robar tus URL de webhook o enviar tus datos de salud a servidores desconocidos. Descarga siempre desde Google Play.</string>
    <string name="dt_steps_name">Pasos</string>
    <string name="dt_steps_rationale">Rastree sus pasos diarios y envíe los datos a su webhook para automatizaciones de ejercicios.</string>
    <string name="dt_sleep_name">Sueño</string>
    <string name="dt_sleep_rationale">Envíe la duración del sueño y fases (ligero, profundo, REM) a su webhook para crear resúmenes de descanso.</string>
    <string name="dt_hr_name">Frecuencia cardíaca</string>
    <string name="dt_hr_rationale">Retransmita sus valores de frecuencia cardíaca para monitorizar el pulso, o alertas de salud.</string>
    <string name="dt_hrv_name">Variabilidad de frecuencia cardíaca</string>
    <string name="dt_hrv_rationale">Mande las mediciones VFC (RMSSD) a su webhook para saber su estrés o estado nervioso a largo plazo.</string>
    <string name="dt_dist_name">Distancia</string>
    <string name="dt_dist_rationale">Pase a diario la distancia registrada al webhook para avances en caminatas, ciclismo, etc.</string>
    <string name="dt_act_cal_name">Calorías activas</string>
    <string name="dt_act_cal_rationale">Envíe datos de quemado calórico dinámico a su webhook para el entrenamiento y estado físico.</string>
    <string name="dt_tot_cal_name">Calorías totales</string>
    <string name="dt_tot_cal_rationale">Genere seguimientos sobre su gasto de calorías y equilibrios energéticos para sistemas de dietas corporales.</string>
    <string name="dt_weight_name">Peso</string>
    <string name="dt_weight_rationale">Envíe registros de cambios con el peso a su webhook para ver tendencias e ingresos del IMC.</string>
    <string name="dt_height_name">Altura</string>
    <string name="dt_height_rationale">Traspase los resultados de estatura a su webhook, esto permite una mayor fluidez a la hora de saber el IMC.</string>
    <string name="dt_bp_name">Presión arterial</string>
    <string name="dt_bp_rationale">Examine directamente sus rutinas o problemas en los vasos sanguíneos para alertas sistólicas y diastólicas.</string>
    <string name="dt_bg_name">Glucosa en sangre</string>
    <string name="dt_bg_rationale">Aposte las cantidades de glucosa de su cuerpo dentro de los parámetros estipulados para seguimientos médicos o alertas del webhook.</string>
    <string name="dt_oxy_name">Saturación de oxígeno</string>
    <string name="dt_oxy_rationale">Concentre las mediciones de SpO2 para obtener notificaciones del aparato respiratorio, así como niveles bajos de O₂.</string>
    <string name="dt_temp_name">Temperatura corporal</string>
    <string name="dt_temp_rationale">Monitoree en su webhook su temperatura para detección de picos por fiebre o variaciones que afecten el organismo.</string>
    <string name="dt_skin_temp_name">Temperatura de la piel</string>
    <string name="dt_skin_temp_rationale">Envíe deltas de temperatura cutánea desde wearables a su webhook para bienestar y seguimiento del sueño.</string>
    <string name="dt_resp_name">Frecuencia respiratoria</string>
    <string name="dt_resp_rationale">Súrtase de su frecuencia de la respiración regular en el webhook como modo de vigilar la buena salud u otras complicaciones.</string>
    <string name="dt_rhr_name">Frecuencia cardíaca en reposo</string>
    <string name="dt_rhr_rationale">Concientice de los picos en el estado de reposo para rastrear el estrés en la base cardiaca a través de su webhook.</string>
    <string name="dt_exer_name">Sesiones de ejercicio</string>
    <string name="dt_exer_rationale">Describa detalladamente el transcurso o clase del entrenamiento deportivo, logrando así rastreo personalizado en el desarrollo con la URL.</string>
    <string name="dt_hydr_name">Hidratación</string>
    <string name="dt_hydr_rationale">Integre y exponga niveles o alertas de ingestión líquida enviando datos automatizados del webhook sobre cantidad reabastecida en tu cuerpo.</string>
    <string name="dt_nutr_name">Nutrición</string>
    <string name="dt_nutr_rationale">Recopile información de todas las aportaciones o porcentajes macro para su bienestar basándose en las combinaciones.</string>
    <string name="dt_bmr_name">Tasa metabólica basal</string>
    <string name="dt_bmr_rationale">Determine las medidas específicas por las TMB dentro las funciones personalizadas del webhook respecto a cómo la salud asimila o pierde grasa.</string>
    <string name="dt_bf_name">Grasa corporal</string>
    <string name="dt_bf_rationale">Muestra las tendencias generales basándose en tu propia perspectiva física enviada directamente para fines útiles o proyecciones comparativas.</string>
    <string name="dt_lbm_name">Masa corporal magra</string>
    <string name="dt_lbm_rationale">Determine cuál es su porcentaje real exento de su volumen muscular usando directamente un registro contable y directo en tu Webhook.</string>
    <string name="dt_vo2_name">VO₂ Máx</string>
    <string name="dt_vo2_rationale">Monitoreo en torno a tu aguante cardiorrespiratorio a partir de las cantidades ingresadas durante la ejercitación y puestas en tu base.</string>
    <string name="dt_bone_name">Masa ósea</string>
    <string name="dt_bone_rationale">Visualice y controle qué de denso resultan ser los atributos esqueléticos dentro todo el entorno que propicias y el Webhook.</string>
    <string name="dt_hc_rationale">Health Connect to Webhook requiere acceso a sus datos de salud y estado físico. Estos datos se utilizan estrictamente para las funcionalidades de la aplicación: transmitir de forma segura sus métricas de salud directamente a sus URL de webhook personales. Nunca venderemos ni compartiremos sus datos. Solo se solicitarán y sincronizarán los datos que configure expresamente.</string>
